{
  "name": "termsnap",
  "version": "1.0.0",
  "description": "Record terminal sessions and export beautiful animated SVGs. One tool, two commands.",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "termsnap": "./bin/termsnap.js"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --outfile bin/termsnap.js --target bun",
    "dev": "bun --watch src/index.ts"
  },
  "keywords": ["terminal", "recording", "svg", "animation", "cli", "readme", "demo", "asciicast"],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  }
}
